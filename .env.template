# Telegram API credentials
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=your_phone_number

# Data collection settings
# DATE CONFIGURATION: Choose ONE of the following options
# Option 1 (RECOMMENDED): Specific start date - scrape from this date onwards
START_DATE=2020-01-01

# Option 2: Relative date - only used if START_DATE is not set
# DATA_MONTHS_BACK=3

# Message limit per channel (increase for collecting data from 2020)
MAX_MESSAGES_PER_CHANNEL=50000

# Analysis settings
SIMILARITY_THRESHOLD=0.75
TIME_WINDOW_HOURS=48
